# Canonical site URL used for metadata, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://lumendermatology.example.com

# Scheduler embed for /book (Calendly, Acuity, or EMR portal URL). Unset →
# the page falls back to the consultation request form.
NEXT_PUBLIC_BOOKING_URL=

# Form delivery via Resend (https://resend.com). Leave RESEND_API_KEY unset
# in dev — submissions are logged to the server console instead.
RESEND_API_KEY=
FORM_TO_EMAIL=hello@lumendermatology.example
FORM_FROM_EMAIL="Lumen Website <onboarding@resend.dev>"
